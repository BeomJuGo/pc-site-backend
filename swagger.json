{
  "openapi": "3.0.3",
  "info": {
    "title": "PC 견적 추천 API",
    "version": "2.0.0",
    "description": "PC 부품 조회·검색·비교, 가격 추세·멀티몰 비교, 견적 저장/공유/PDF, 가격 알림, 호환성 검사, AI 추천·업그레이드 어드바이저 API"
  },
  "servers": [
    { "url": "/", "description": "Current server" }
  ],
  "tags": [
    { "name": "system", "description": "서버 상태" },
    { "name": "parts", "description": "부품 조회·검색·비교" },
    { "name": "prices", "description": "멀티몰 실시간 가격 비교" },
    { "name": "builds", "description": "견적 저장·공유·PDF" },
    { "name": "alerts", "description": "가격 알림" },
    { "name": "compatibility", "description": "호환성 검사" },
    { "name": "recommend", "description": "AI 추천 · 업그레이드 어드바이저" }
  ],
  "components": {
    "schemas": {
      "Part": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "category": { "type": "string", "enum": ["cpu","gpu","motherboard","memory","storage","psu","case","cooler"] },
          "name": { "type": "string" },
          "price": { "type": "integer" },
          "benchmarkScore": { "type": "object" },
          "specs": { "type": "object" },
          "info": { "type": "string" },
          "specSummary": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "details": { "type": "string" }
        }
      }
    },
    "parameters": {
      "category": {
        "name": "category", "in": "path", "required": true,
        "schema": { "type": "string", "enum": ["cpu","gpu","motherboard","memory","storage","psu","case","cooler"] }
      },
      "partName": {
        "name": "name", "in": "path", "required": true,
        "schema": { "type": "string" },
        "description": "부품 이름 (URL 인코딩)"
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["system"],
        "summary": "서버 상태 확인",
        "responses": {
          "200": {
            "description": "서버 정상",
            "content": {
              "application/json": {
                "example": {
                  "status": "OK",
                  "timestamp": "2026-04-21T00:00:00.000Z",
                  "uptime": 3600,
                  "db": "connected",
                  "memory": { "rss": "120MB", "heapUsed": "60MB" },
                  "openai": true
                }
              }
            }
          }
        }
      }
    },
    "/api/parts": {
      "get": {
        "tags": ["parts"],
        "summary": "부품 목록 조회 (페이징)",
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string", "enum": ["cpu","gpu","motherboard","memory","storage","psu","case","cooler"] } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100, "maximum": 200 } }
        ],
        "responses": {
          "200": { "description": "부품 목록 (헤더: X-Total-Count, X-Page, X-Total-Pages)" }
        }
      }
    },
    "/api/parts/search": {
      "get": {
        "tags": ["parts"],
        "summary": "부품 검색 (이름·카테고리·가격범위·정렬)",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "검색어 (이름 포함 매칭)" },
          { "name": "category", "in": "query", "schema": { "type": "string", "enum": ["cpu","gpu","motherboard","memory","storage","psu","case","cooler"] } },
          { "name": "manufacturer", "in": "query", "schema": { "type": "string" }, "description": "제조사 필터" },
          { "name": "priceMin", "in": "query", "schema": { "type": "integer" } },
          { "name": "priceMax", "in": "query", "schema": { "type": "integer" } },
          { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["price_asc","price_desc","score_desc","value_desc"], "default": "price_asc" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 100 } }
        ],
        "responses": {
          "200": { "description": "검색 결과 배열" },
          "400": { "description": "q 또는 category 중 하나 필수" }
        }
      }
    },
    "/api/parts/value-rank": {
      "get": {
        "tags": ["parts"],
        "summary": "가성비 랭킹 (벤치마크 점수 ÷ 가격)",
        "parameters": [
          { "name": "category", "in": "query", "required": true, "schema": { "type": "string", "enum": ["cpu","gpu","memory","storage"] } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 50 } }
        ],
        "responses": {
          "200": { "description": "가성비 순 부품 목록 (_valueScore 필드 포함)" }
        }
      }
    },
    "/api/parts/budget-picks": {
      "get": {
        "tags": ["parts"],
        "summary": "예산별 카테고리별 최적 부품 추천 (MongoDB $facet 집계)",
        "parameters": [
          { "name": "budget", "in": "query", "required": true, "schema": { "type": "integer", "example": 1500000 }, "description": "총 예산 원화" }
        ],
        "responses": {
          "200": {
            "description": "예산 배분 및 카테고리별 TOP 3",
            "content": {
              "application/json": {
                "example": {
                  "budget": 1500000,
                  "budgetAllocation": { "cpu": 375000, "gpu": 600000 },
                  "picks": { "cpu": [], "gpu": [] }
                }
              }
            }
          }
        }
      }
    },
    "/api/parts/batch": {
      "post": {
        "tags": ["parts"],
        "summary": "부품 일괄 조회 (최대 50개)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "items": [
                  { "category": "cpu", "name": "AMD Ryzen 5 7600X" },
                  { "category": "gpu", "name": "ASUS TUF GAMING RTX 4070" }
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "조회된 부품 배열 (찾지 못한 항목 제외)" }
        }
      }
    },
    "/api/parts/compare": {
      "post": {
        "tags": ["parts"],
        "summary": "부품 비교 (2~5개, 가격·점수·가성비 비교)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "parts": [
                  { "category": "cpu", "name": "AMD Ryzen 5 7600X" },
                  { "category": "cpu", "name": "Intel Core i5-13600K" }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "비교 결과 (_isBestPrice, _isBestScore, _isBestValue, _scoreVsMax 포함)",
            "content": {
              "application/json": {
                "example": {
                  "count": 2,
                  "parts": [
                    { "name": "AMD Ryzen 5 7600X", "price": 250000, "_totalScore": 25000, "_valueScore": 0.1, "_isBestValue": true }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/parts/danawa-url": {
      "get": {
        "tags": ["parts"],
        "summary": "다나와 검색 URL 생성",
        "parameters": [
          { "name": "name", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "{ url, name }" }
        }
      }
    },
    "/api/parts/{category}/{name}": {
      "get": {
        "tags": ["parts"],
        "summary": "부품 상세 조회",
        "parameters": [
          { "$ref": "#/components/parameters/category" },
          { "$ref": "#/components/parameters/partName" }
        ],
        "responses": {
          "200": { "description": "부품 상세 정보" },
          "404": { "description": "부품 없음" }
        }
      }
    },
    "/api/parts/{category}/{name}/history": {
      "get": {
        "tags": ["parts"],
        "summary": "부품 가격 히스토리 전체 조회",
        "parameters": [
          { "$ref": "#/components/parameters/category" },
          { "$ref": "#/components/parameters/partName" }
        ],
        "responses": {
          "200": { "description": "{ name, category, priceHistory[] }" }
        }
      }
    },
    "/api/parts/{category}/{name}/trend": {
      "get": {
        "tags": ["parts"],
        "summary": "가격 추세 분석 (30·60·90일 최저·최고·평균·변동률)",
        "parameters": [
          { "$ref": "#/components/parameters/category" },
          { "$ref": "#/components/parameters/partName" }
        ],
        "responses": {
          "200": {
            "description": "기간별 가격 통계",
            "content": {
              "application/json": {
                "example": {
                  "name": "AMD Ryzen 5 7600X",
                  "category": "cpu",
                  "currentPrice": 250000,
                  "trends": [
                    { "days": 30, "min": 240000, "max": 260000, "avg": 250000, "change": -2.5, "count": 30 }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/prices/{category}/{name}": {
      "get": {
        "tags": ["prices"],
        "summary": "멀티몰 실시간 가격 비교 (네이버 쇼핑, 1시간 캐시)",
        "parameters": [
          { "$ref": "#/components/parameters/category" },
          { "$ref": "#/components/parameters/partName" }
        ],
        "responses": {
          "200": {
            "description": "멀티몰 가격 목록 + 최저가 요약",
            "content": {
              "application/json": {
                "example": {
                  "name": "AMD Ryzen 5 7600X",
                  "category": "cpu",
                  "storedPrice": 250000,
                  "lowestPrice": 243000,
                  "lowestMall": "쿠팡",
                  "priceGap": 7000,
                  "inStock": true,
                  "mallCount": 8,
                  "naverMalls": [
                    { "mallName": "쿠팡", "price": 243000, "link": "https://..." }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/prices/batch": {
      "post": {
        "tags": ["prices"],
        "summary": "빌드 전체 멀티몰 가격 일괄 조회 (최대 8개)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "parts": [
                  { "category": "cpu", "name": "AMD Ryzen 5 7600X" },
                  { "category": "gpu", "name": "ASUS TUF GAMING RTX 4070" }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "부품별 최저가 + 합계 요약",
            "content": {
              "application/json": {
                "example": {
                  "parts": [],
                  "summary": {
                    "totalLowest": 1200000,
                    "totalStored": 1250000,
                    "saving": 50000,
                    "allInStock": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/builds": {
      "post": {
        "tags": ["builds"],
        "summary": "견적 저장 및 공유 링크 생성 (30일 유효)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "builds": [
                  { "category": "cpu", "name": "AMD Ryzen 5 7600X", "price": 250000 },
                  { "category": "gpu", "name": "ASUS TUF GAMING RTX 4070", "price": 550000 }
                ],
                "purpose": "게임용",
                "budget": 1500000
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "공유 ID 및 만료일",
            "content": {
              "application/json": {
                "example": { "shareId": "a1b2c3d4", "expiresAt": "2026-05-21T00:00:00.000Z" }
              }
            }
          }
        }
      }
    },
    "/api/builds/{shareId}": {
      "get": {
        "tags": ["builds"],
        "summary": "공유 견적 조회",
        "parameters": [
          { "name": "shareId", "in": "path", "required": true, "schema": { "type": "string", "example": "a1b2c3d4" } }
        ],
        "responses": {
          "200": { "description": "견적 정보" },
          "404": { "description": "견적 없음" },
          "410": { "description": "만료된 견적" }
        }
      }
    },
    "/api/builds/{shareId}/pdf": {
      "get": {
        "tags": ["builds"],
        "summary": "견적 PDF 다운로드",
        "parameters": [
          { "name": "shareId", "in": "path", "required": true, "schema": { "type": "string", "example": "a1b2c3d4" } }
        ],
        "responses": {
          "200": {
            "description": "PDF 파일",
            "content": { "application/pdf": {} }
          },
          "404": { "description": "견적 없음" },
          "410": { "description": "만료된 견적" }
        }
      }
    },
    "/api/alerts": {
      "post": {
        "tags": ["alerts"],
        "summary": "가격 알림 등록",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "category": "gpu",
                "name": "ASUS TUF GAMING RTX 4070",
                "targetPrice": 500000,
                "email": "user@example.com"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "알림 등록 완료" },
          "409": { "description": "동일 알림 이미 존재" }
        }
      },
      "get": {
        "tags": ["alerts"],
        "summary": "내 가격 알림 목록 조회",
        "parameters": [
          { "name": "email", "in": "query", "required": true, "schema": { "type": "string", "format": "email" } }
        ],
        "responses": {
          "200": { "description": "알림 목록" }
        }
      }
    },
    "/api/alerts/{id}": {
      "delete": {
        "tags": ["alerts"],
        "summary": "가격 알림 삭제",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "삭제 완료" },
          "404": { "description": "알림 없음" }
        }
      }
    },
    "/api/compatibility/check": {
      "post": {
        "tags": ["compatibility"],
        "summary": "부품 호환성 검사 (소켓·DDR·PSU 전력·폼팩터·쿨러)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "parts": {
                  "cpu": "AMD Ryzen 5 7600X",
                  "motherboard": "ASUS ROG STRIX B650E-F GAMING WIFI",
                  "memory": "Samsung DDR5-4800 16GB",
                  "psu": "Seasonic Focus GX-750",
                  "cooler": "Noctua NH-D15",
                  "case": "Fractal Design Define 7"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "호환성 검사 결과",
            "content": {
              "application/json": {
                "example": {
                  "compatible": true,
                  "issues": [],
                  "warnings": ["PSU 여유 부족: 750W (820W 이상 권장)"],
                  "info": { "cpuSocket": "AM5", "boardSocket": "AM5", "boardDdr": "DDR5", "memDdr": "DDR5" },
                  "summary": "호환 가능 (주의사항 있음)"
                }
              }
            }
          }
        }
      }
    },
    "/api/recommend": {
      "post": {
        "tags": ["recommend"],
        "summary": "AI 기반 PC 견적 추천 (GPT-4o-mini, 24h 캐시)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": { "budget": 1500000, "purpose": "게임용" }
            }
          }
        },
        "responses": {
          "200": { "description": "추천 견적 목록 + AI 평가" },
          "429": { "description": "요청 횟수 초과 (분당 10회)" }
        }
      }
    },
    "/api/recommend/upgrade": {
      "post": {
        "tags": ["recommend"],
        "summary": "업그레이드 어드바이저 (현재 빌드 기반 용도별 추천)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "currentBuild": {
                  "cpu": "AMD Ryzen 5 5600X",
                  "gpu": "NVIDIA GTX 1080 Ti"
                },
                "budget": 700000,
                "purpose": "게임용"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "업그레이드 제안 목록 (개선율 포함)",
            "content": {
              "application/json": {
                "example": {
                  "suggestions": [
                    {
                      "category": "gpu",
                      "reason": "게임 성능의 핵심은 GPU입니다.",
                      "priority": 1,
                      "candidates": [
                        { "name": "ASUS TUF GAMING RTX 4070", "price": 650000, "_improvement": 85 }
                      ]
                    }
                  ],
                  "summary": "GPU 업그레이드를 우선 권장합니다."
                }
              }
            }
          }
        }
      }
    },
    "/api/gpt-info": {
      "post": {
        "tags": ["parts"],
        "summary": "GPT 부품 한줄평 + 사양 요약 (분당 10회 제한)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": { "partName": "AMD Ryzen 5 7600X" }
            }
          }
        },
        "responses": {
          "200": { "description": "{ review, specSummary }" },
          "429": { "description": "요청 횟수 초과" }
        }
      }
    },
    "/api/naver-price": {
      "get": {
        "tags": ["prices"],
        "summary": "네이버 쇼핑 원시 검색 (직접 쿼리)",
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "네이버 쇼핑 API 원본 응답" }
        }
      }
    }
  }
}
